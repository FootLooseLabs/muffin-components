{
  "version": "0.1.0",
  "components": {
    "json-editor": {
      "domElName": "json-editor",
      "description": "JSON editor component powered by Ace editor — supports placeholder, default value, repeat-schema for array data entry",
      "cdn": "https://cdn.jsdelivr.net/gh/FootLooseLabs/muffin-components/components/json-editor/index.js",
      "import": "@muffin/components/components/json-editor/index.js",
      "attributes": {
        "value": "JSON string — initial value loaded into the editor",
        "placeholder": "JSON string — shown when editor is empty"
      },
      "tags": ["editor", "json", "form", "input", "data", "ace", "syntax-highlight"],
      "usage": [
        {
          "label": "minimal",
          "code": "<json-editor></json-editor>"
        },
        {
          "label": "with default value",
          "code": "<json-editor value='{\"key\": \"value\"}'></json-editor>"
        },
        {
          "label": "with placeholder",
          "code": "<json-editor placeholder='{\"key\": \"value\"}'></json-editor>"
        },
        {
          "label": "with inline repeat-schema",
          "code": "<json-editor>\n  <repeat-schema key=\"items\">{\"name\": \"\", \"value\": \"\"}</repeat-schema>\n</json-editor>"
        }
      ]
    },
    "lucide-icon": {
      "domElName": "lucide-icon",
      "description": "Renders any Lucide icon as an inline SVG. Accepts kebab-case icon names (e.g. chevrons-right, share-2). Also exposes a static renderIcon() helper for use inside other components.",
      "cdn": "https://cdn.jsdelivr.net/gh/FootLooseLabs/muffin-components/components/lucide-icon/index.js",
      "import": "@muffin/components/components/lucide-icon/index.js",
      "attributes": {
        "icon": "Kebab-case Lucide icon name (e.g. \"chevrons-right\", \"share-2\") — required",
        "size": "Icon size in pixels — default 16",
        "class": "CSS class applied to the SVG element"
      },
      "tags": ["icon", "svg", "lucide", "utility", "display"],
      "usage": [
        {
          "label": "minimal",
          "code": "<lucide-icon></lucide-icon>"
        },
        {
          "label": "named icon",
          "code": "<lucide-icon icon=\"chevrons-right\"></lucide-icon>"
        },
        {
          "label": "with size and class",
          "code": "<lucide-icon icon=\"share-2\" size=\"24\" class=\"text-blue-500\"></lucide-icon>"
        },
        {
          "label": "static helper inside another component",
          "code": "LucideIcon.renderIcon('trash-2', 20, 'text-red-500')"
        }
      ]
    }
  }
}
